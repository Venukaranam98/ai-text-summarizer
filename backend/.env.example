# --- Database ---
# Use the postgresql+psycopg:// prefix (psycopg3 driver). If using Neon, copy your connection
# string from the Neon dashboard and swap postgresql:// for postgresql+psycopg:// at the start.
DATABASE_URL=postgresql+psycopg://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# --- JWT ---
SECRET_KEY=change-this-to-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Groq LLM ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- CORS ---
# Comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate limiting ---
SUMMARY_RATE_LIMIT=10/minute